# ============================================================
# Application Configuration
# ============================================================

# App
APP_NAME=AI Pharmacovigilance Intelligence Platform
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# API Gateway
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501

# Database
DATABASE_URL=sqlite:///./data/pharmacovigilance.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# NLP Service
SPACY_MODEL=en_core_web_sm
NLP_BATCH_SIZE=32
NLP_MAX_TEXT_LENGTH=10000

# Risk Detection
SIGNAL_THRESHOLD=2.0
ANOMALY_CONTAMINATION=0.05
MIN_REPORTS_FOR_SIGNAL=3

# AI Assistant
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1000

# Reporting
REPORT_OUTPUT_DIR=data/exports
MAX_REPORT_ROWS=50000

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# Data
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SYNTHETIC_DATASET_SIZE=10000

# CORS
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000","http://127.0.0.1:8501"]
